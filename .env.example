# CTEH Platform Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit .env files to version control

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
MAX_REQUEST_SIZE=10mb

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/cteh

# MongoDB Connection Options
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis Connection URL
REDIS_URL=redis://localhost:6379

# Redis Connection Options
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_ON_FAILURE_MS=100
REDIS_ENABLE_READY_CHECK=true
REDIS_MAX_RETRIES_PER_REQUEST=3

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Configuration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=cteh-platform
JWT_AUDIENCE=cteh-users

# Password Security
BCRYPT_ROUNDS=12

# Account Security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME_MS=900000
PASSWORD_RESET_EXPIRES_MS=3600000

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_MAX_AGE_MS=86400000

# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# AI Service Configuration
AI_CACHE_TTL_SECONDS=3600
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=3

# =============================================================================
# AZURE SERVICES
# =============================================================================
# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=cteh-uploads

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=your-service-bus-connection-string

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string
APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# Azure Cognitive Services
AZURE_COGNITIVE_SERVICES_KEY=your-cognitive-services-key
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Email Service Provider (smtp, sendgrid, mailgun, ses)
EMAIL_PROVIDER=smtp

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Email Templates
EMAIL_FROM_ADDRESS=noreply@cteh.cognizant.com
EMAIL_FROM_NAME=CTEH Platform
EMAIL_REPLY_TO=support@cteh.cognizant.com

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Log Level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# Log File Configuration
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/cteh.log
LOG_FILE_MAX_SIZE=5m
LOG_FILE_MAX_FILES=5

# Console Logging
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_COLORIZE=true

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Upload Limits
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Upload Storage
UPLOAD_STORAGE_TYPE=local
UPLOAD_LOCAL_PATH=uploads/
UPLOAD_TEMP_PATH=temp/

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================
# WebSocket Server
WEBSOCKET_PORT=3001
WEBSOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Socket.IO Configuration
SOCKETIO_TRANSPORTS=websocket,polling
SOCKETIO_PING_TIMEOUT_MS=60000
SOCKETIO_PING_INTERVAL_MS=25000

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Cache TTL (Time To Live) in seconds
CACHE_DEFAULT_TTL=3600
CACHE_USER_TTL=1800
CACHE_SKILLS_TTL=7200
CACHE_LEARNING_PATHS_TTL=3600

# Cache Key Prefixes
CACHE_PREFIX=cteh:
CACHE_USER_PREFIX=user:
CACHE_SKILLS_PREFIX=skills:
CACHE_SESSION_PREFIX=session:

# =============================================================================
# RATE LIMITING
# =============================================================================
# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Authentication Rate Limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
# Analytics Service
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL_MS=30000

# Event Tracking
TRACK_USER_EVENTS=true
TRACK_API_REQUESTS=true
TRACK_PERFORMANCE_METRICS=true

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================
# Cron Jobs
ENABLE_SCHEDULED_JOBS=true
CLEANUP_JOB_CRON=0 2 * * *
ANALYTICS_JOB_CRON=*/15 * * * *
BACKUP_JOB_CRON=0 3 * * 0

# Job Configuration
JOB_CONCURRENCY=5
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=5000

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Feature Toggles
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_PEER_RECOGNITION=true
FEATURE_AI_INTERVIEWS=true
FEATURE_CALENDAR_INTEGRATION=true
FEATURE_SKILL_TRACKING=true
FEATURE_TEAM_SPACES=true
FEATURE_MENTOR_MATCHING=true
FEATURE_FEEDBACK_TOOLS=true
FEATURE_CAREER_VISUALIZER=true
FEATURE_ANALYTICS_DASHBOARD=true

# Beta Features
BETA_ADVANCED_ANALYTICS=false
BETA_AI_COACHING=false
BETA_MOBILE_APP=false

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development Tools
ENABLE_API_DOCS=true
ENABLE_GRAPHQL_PLAYGROUND=false
ENABLE_PROFILING=false

# Debug Configuration
DEBUG_SQL=false
DEBUG_REDIS=false
DEBUG_WEBSOCKETS=false

# Mock Services (for development/testing)
MOCK_AI_SERVICE=false
MOCK_EMAIL_SERVICE=false
MOCK_AZURE_SERVICES=false

# =============================================================================
# MONITORING & HEALTH CHECKS
# =============================================================================
# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_MS=5000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Security Headers
ENABLE_HELMET=true
ENABLE_CORS=true
ENABLE_COMPRESSION=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# API Security
API_KEY_HEADER=X-API-Key
REQUIRE_API_KEY=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Microsoft Graph API (for calendar integration)
MS_GRAPH_CLIENT_ID=your-ms-graph-client-id
MS_GRAPH_CLIENT_SECRET=your-ms-graph-client-secret
MS_GRAPH_TENANT_ID=your-ms-graph-tenant-id

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Teams Integration
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/your-webhook-url

# GitHub Integration (for CI/CD notifications)
GITHUB_TOKEN=your-github-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# =============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# =============================================================================
# These can be overridden in environment-specific files
# .env.development, .env.staging, .env.production

# Database Connection Pooling
DB_POOL_MIN=2
DB_POOL_MAX=10

# Cache Configuration
CACHE_MEMORY_LIMIT_MB=100

# Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=cteh-platform
APM_SERVICE_VERSION=1.0.0